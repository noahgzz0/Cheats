-- [HWID FUNCTIONS]
-- ==========================================================

local function GetHWID()
    if gethwid then return gethwid() end
    if syn and syn.get_hwid then return syn.get_hwid() end
    return nil
end

local function LoadLocks()
    local locks = {}
    if isfile and isfile(LOCK_FILE) then
        local content = readfile(LOCK_FILE)
        for line in content:gmatch("[^\n]+") do
            local key, hwid, ts, ktype = line:match("^(.+)=(.+)|(%d+)|(.+)$")
            if key then
                locks[key] = { hwid = hwid, time = tonumber(ts), ktype = ktype }
            end
        end
    end
    return locks
end

local function SaveLocks(locks)
    if not writefile then return end
    local lines = {}
    for key, data in pairs(locks) do
        table.insert(lines, key .. "=" .. data.hwid .. "|" .. tostring(data.time) .. "|" .. data.ktype)
    end
    writefile(LOCK_FILE, table.concat(lines, "\n"))
end

local function CheckSavedKey()
    if not isfile or not readfile then return false end
    if not isfile(FILE_NAME) then return false end
    local content = readfile(FILE_NAME)
    local savedHWID, ktype, ts = content:match("^(.+)|(.+)|(%d+)$")
    if not savedHWID then return false end
    local currentHWID = GetHWID()
    if not currentHWID or savedHWID ~= currentHWID then return false end
    if ktype == "PERMANENT" then return true end
    if ktype == "24H" and (os.time() - tonumber(ts)) < 86400 then return true end
    return false
end

local function SaveSession(ktype)
    if not writefile then return end
    local hwid = GetHWID()
    if not hwid then return end
    writefile(FILE_NAME, hwid .. "|" .. ktype .. "|" .. tostring(os.time()))
end

local function ValidateKey(inputKey)
    local currentHWID = GetHWID()
    if not currentHWID then
        return false, "UNSUPPORTED EXECUTOR"
    end

    local locks = LoadLocks()

    local is24h = false
    for _, k in pairs(STANDARD_KEYS) do
        if inputKey == k then is24h = true break end
    end

    local isPerm = false
    if not is24h then
        for _, k in pairs(PERM_KEYS) do
            if inputKey == k then isPerm = true break end
        end
    end

    if not is24h and not isPerm then
        return false, "INVALID KEY"
    end

    local lockData = locks[inputKey]
    if lockData then
        if lockData.hwid ~= currentHWID then
            return false, "KEY LOCKED TO\nANOTHER DEVICE"
        end
        if lockData.ktype == "24H" and (os.time() - lockData.time) >= 86400 then
            locks[inputKey] = nil
            SaveLocks(locks)
            return false, "KEY EXPIRED"
        end
    else
        locks[inputKey] = {
            hwid = currentHWID,
            time = os.time(),
            ktype = isPerm and "PERMANENT" or "24H"
        }
        SaveLocks(locks)
    end

    return true, isPerm and "PERMANENT" or "24H"
end


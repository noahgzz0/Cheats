local function AddLog(text)
    LogBox.Text = LogBox.Text .. "\n> " .. text
    LogBox.CursorPosition = #LogBox.Text + 1
end

local function ParseResult(data)
    local packet = data
    if type(data) == "table" and data[1] then packet = data[1] end
    if type(packet) == "table" then
        local name = packet.Item or packet.Vehicle or packet.Car or packet.Part or packet.Name
        local rarity = packet.Rarity or packet.Type
        if name then
            return tostring(name) .. (rarity and (" ["..tostring(rarity).."]") or "")
        end
        return HttpService:JSONEncode(packet)
    end
    return tostring(packet)
end

local function SwitchTab(mode, remote, btn)
    BtnImport.BackgroundColor3 = COLORS.Element
    BtnFusion.BackgroundColor3 = COLORS.Element
    BtnParts.BackgroundColor3 = COLORS.Element
    BtnFarm.BackgroundColor3 = COLORS.Element
    btn.BackgroundColor3 = (mode == "Farm") and COLORS.Success or COLORS.Accent
    if mode == "Farm" then
        CratePage.Visible = false
        FarmPage.Visible = true
        currentRemote = nil
    else
        CratePage.Visible = true
        FarmPage.Visible = false
        currentRemote = remote
    end
end


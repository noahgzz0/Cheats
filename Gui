-- SERVICES
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

-- CONFIGURATION
local player = Players.LocalPlayer
-- FIX: Automatically use the current account's username
local CAR_NAME = player.Name 

local DRIVE_SPEED = 591
local START_POS = Vector3.new(4846, 8, 19120)
local DIRECTION = Vector3.new(0, 0, 1)

-- STATE VARIABLES
local farming = false
local heartBeatConnection = nil

-- 1. UI CREATION
local ScreenGui = Instance.new("ScreenGui")
if pcall(function() return CoreGui end) then
    ScreenGui.Parent = CoreGui
else
    ScreenGui.Parent = player:WaitForChild("PlayerGui")
end
ScreenGui.Name = "AutoFarmUI"

local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Name = "ToggleBtn"
ToggleBtn.Parent = ScreenGui
ToggleBtn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
ToggleBtn.Position = UDim2.new(0.1, 0, 0.1, 0)
ToggleBtn.Size = UDim2.new(0, 150, 0, 50)
ToggleBtn.Font = Enum.Font.GothamBold
ToggleBtn.Text = "START FARM"
ToggleBtn.TextColor3 = Color3.new(1, 1, 1)
ToggleBtn.TextSize = 20
ToggleBtn.BorderSizePixel = 0
ToggleBtn.AutoButtonColor = true

local Corner = Instance.new("UICorner")
Corner.CornerRadius = UDim.new(0, 8)
Corner.Parent = ToggleBtn

-- 2. FUNCTIONS

local function StopFarm()
    -- Disconnect loop
    if heartBeatConnection then
        heartBeatConnection:Disconnect()
        heartBeatConnection = nil
    end
    
    -- Reset Physics
    -- FIX: Use the dynamic CAR_NAME here
    local car = workspace.AVehicleStorage:FindFirstChild(CAR_NAME)
    local seat = car and car:FindFirstChildWhichIsA("VehicleSeat", true)
    
    if seat then
        seat.AssemblyLinearVelocity = Vector3.zero
        seat.AssemblyAngularVelocity = Vector3.zero
        seat.Anchored = true
        task.wait(0.1)
        seat.Anchored = false
    end
    
    -- Restore Traffic
    local traffic = workspace:FindFirstChild("AITraffic")
    if traffic then
        for _, npc in ipairs(traffic:GetChildren()) do
            for _, part in ipairs(npc:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanTouch = true
                    part.CanCollide = true
                end
            end
        end
    end

    farming = false
    ToggleBtn.Text = "START FARM"
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
end

local function StartFarm()
    -- FIX: Update the target car to the current player's name
    CAR_NAME = player.Name 
    local car = workspace.AVehicleStorage:WaitForChild(CAR_NAME, 5) -- Added timeout to prevent infinite hang
    
    if not car then
        warn("Car not found! Make sure you have spawned a vehicle.")
        return
    end

    local seat = car:FindFirstChildWhichIsA("VehicleSeat", true)
    local traffic = workspace:WaitForChild("AITraffic")

    -- Physics Reset
    for _, p in ipairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            p.Anchored = false 
            p.CanCollide = false
            p.AssemblyLinearVelocity = Vector3.zero
            p.AssemblyAngularVelocity = Vector3.zero
        end
    end
    
    farming = true
    ToggleBtn.Text = "STOP FARM"
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
    
    heartBeatConnection = RunService.Heartbeat:Connect(function()
        if not farming then return end
        
        if seat then
            seat.AssemblyLinearVelocity = DIRECTION * DRIVE_SPEED
            seat.AssemblyAngularVelocity = Vector3.zero
            
            local currentZ = seat.Position.Z
            seat.CFrame = CFrame.new(START_POS.X, 8, currentZ) * CFrame.Angles(0, 0, 0)
            seat.Throttle = 1
        end

        if traffic then
            for _, npc in ipairs(traffic:GetChildren()) do
                for _, part in ipairs(npc:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanTouch = false
                        part.CanCollide = false
                    end
                end
            end
        end
    end)
end

-- 3. BUTTON LISTENER
ToggleBtn.MouseButton1Click:Connect(function()
    if farming then
        StopFarm()
    else
        StartFarm()
    end
end)

end)

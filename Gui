-- 2. FUNCTIONS

local function StopFarm()
    -- A. Disconnect Loop
    if heartBeatConnection then
        heartBeatConnection:Disconnect()
        heartBeatConnection = nil
    end
    
    -- B. Reset Physics (Your logic)
    local car = workspace.AVehicleStorage:FindFirstChild(CAR_NAME)
    local seat = car and car:FindFirstChildWhichIsA("VehicleSeat", true)
    
    if seat then
        -- Kill forces
        seat.AssemblyLinearVelocity = Vector3.zero
        seat.AssemblyAngularVelocity = Vector3.zero
        
        -- Anchor reset to strictly kill momentum
        seat.Anchored = true
        task.wait(0.1)
        seat.Anchored = false
    end
    
    -- C. Restore Traffic Collisions
    local traffic = workspace:FindFirstChild("AITraffic")
    if traffic then
        for _, npc in ipairs(traffic:GetChildren()) do
            for _, part in ipairs(npc:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanTouch = true
                    part.CanCollide = true
                end
            end
        end
    end

    -- Visual Update
    farming = false
    ToggleBtn.Text = "START FARM"
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(46, 204, 113) -- Green
end

local function StartFarm()
    local car = workspace.AVehicleStorage:WaitForChild(CAR_NAME)
    local seat = car:FindFirstChildWhichIsA("VehicleSeat", true)
    local traffic = workspace:WaitForChild("AITraffic")

    if not seat then 
        warn("Car/Seat not found!") 
        return 
    end

    -- A. Initial Physics Reset
    for _, p in ipairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            p.Anchored = false 
            p.CanCollide = false
            p.AssemblyLinearVelocity = Vector3.zero
            p.AssemblyAngularVelocity = Vector3.zero
        end
    end
    
    farming = true
    ToggleBtn.Text = "STOP FARM"
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(231, 76, 60) -- Red
    
    -- B. The Heartbeat Loop
    heartBeatConnection = RunService.Heartbeat:Connect(function()
        if not farming then return end -- Safety check
        
        if seat then
            -- Velocity Lock
            seat.AssemblyLinearVelocity = DIRECTION * DRIVE_SPEED
            seat.AssemblyAngularVelocity = Vector3.zero
            
            -- CFrame Lock (X/Y Only)
            local currentZ = seat.Position.Z
            seat.CFrame = CFrame.new(START_POS.X, 8, currentZ) * CFrame.Angles(0, 0, 0)
            seat.Throttle = 1
        end

        -- Ghost Traffic
        if traffic then
            for _, npc in ipairs(traffic:GetChildren()) do
                for _, part in ipairs(npc:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanTouch = false
                        part.CanCollide = false
                    end
                end
            end
        end
    end)
end

-- 3. BUTTON LISTENER
ToggleBtn.MouseButton1Click:Connect(function()
    if farming then
        StopFarm()
    else
        StartFarm()
    end
end)

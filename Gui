    local function StopFarm()
        if farmConnection then farmConnection:Disconnect() farmConnection = nil end
        local carName = player.Name
        local car = workspace.AVehicleStorage:FindFirstChild(carName)
        local seat = car and car:FindFirstChildWhichIsA("VehicleSeat", true)
        if seat then
            seat.AssemblyLinearVelocity = Vector3.zero
            seat.AssemblyAngularVelocity = Vector3.zero
            seat.Anchored = true
            task.wait(0.1)
            seat.Anchored = false
        end
        local traffic = workspace:FindFirstChild("AITraffic")
        if traffic then
            for _, npc in ipairs(traffic:GetChildren()) do
                for _, part in ipairs(npc:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanTouch = true part.CanCollide = true end
                end
            end
        end
        farming = false
        FarmToggle.Text = "ENABLE AUTOFARM"
        FarmToggle.BackgroundColor3 = COLORS.Success
        FarmStatus.Text = "STATUS: IDLE"
        FarmStatus.TextColor3 = COLORS.SubText
        AddLog("Autofarm Stopped.")
    end

    local function StartFarm()
        local carName = player.Name
        local car = workspace.AVehicleStorage:WaitForChild(carName, 5)
        if not car then AddLog("Error: Car not found!") return end
        local seat = car:FindFirstChildWhichIsA("VehicleSeat", true)
        local traffic = workspace:WaitForChild("AITraffic")
        for _, p in ipairs(car:GetDescendants()) do
            if p:IsA("BasePart") then
                p.Anchored = false p.CanCollide = false
                p.AssemblyLinearVelocity = Vector3.zero p.AssemblyAngularVelocity = Vector3.zero
            end
        end
        farming = true
        FarmToggle.Text = "STOP AUTOFARM"
        FarmToggle.BackgroundColor3 = COLORS.Danger
        FarmStatus.Text = "STATUS: RUNNING..."
        FarmStatus.TextColor3 = COLORS.Success
        AddLog("Autofarm Started!")
        farmConnection = RunService.Heartbeat:Connect(function()
            if not farming then return end
            if seat then
                seat.AssemblyLinearVelocity = FARM_DIRECTION * FARM_SPEED
                seat.AssemblyAngularVelocity = Vector3.zero
                local currentZ = seat.Position.Z
                seat.CFrame = CFrame.new(FARM_START_POS.X, 8, currentZ) * CFrame.Angles(0, 0, 0)
                seat.Throttle = 1
            end
            if traffic then
                for _, npc in ipairs(traffic:GetChildren()) do
                    for _, part in ipairs(npc:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanTouch = false part.CanCollide = false end
                    end
                end
            end
        end)
    end

    FarmToggle.MouseButton1Click:Connect(function()
        if farming then StopFarm() else StartFarm() end
    end)

-- CONFIGURATION
local CAR_NAME = "noahh8839"
local DRIVE_SPEED = 591
local START_POS = Vector3.new(4846, 8, 19120)
local DIRECTION = Vector3.new(0, 0, 1)

-- STATE VARIABLES
local farming = false
local heartBeatConnection = nil
local player = Players.LocalPlayer


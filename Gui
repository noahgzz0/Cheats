    local function ParseResult(data)
        local packet = data
        if type(data) == "table" and data[1] then packet = data[1] end
        if type(packet) == "table" then
            local name = packet.Item or packet.Vehicle or packet.Car or packet.Part or packet.Name
            local rarity = packet.Rarity or packet.Type
            if name then
                return tostring(name) .. (rarity and (" ["..tostring(rarity).."]") or "")
            end
            return HttpService:JSONEncode(packet)
        end
        return tostring(packet)
    end

